## You invoke this with --env android.alpha on the fastlane command
## Deploys to Google Play closed testing (alpha track)
BETA_BUILD=true
BUILD_FOR_RELEASE=true
COLLECT_NETWORK_METRICS=true
MAIN_APP_IDENTIFIER=com.infomaniak.chat
REPLACE_ASSETS=false
SEPARATE_APKS=true
SUPPLY_TRACK=alpha
SUPPLY_PACKAGE_NAME=com.infomaniak.chat
SUPPLY_VALIDATE_ONLY=false
